# poc-import local configuration
WFP_API_URL=http://localhost:5000

# JWT configuration (aligned with .env.development)
JWT_SECRET_KEY=dev-jwt-secret-change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES=3600

# Optional email claim for local token generation
WFP_JWT_EMAIL=user@example.com

# Shared user/company IDs for local token generation
WFP_USER_ID=79ee5304-1c98-4ae3-b83c-cb47b3549480
WFP_COMPANY_ID=9a7aa1bb-10ea-4142-afdb-217ab520caf1
